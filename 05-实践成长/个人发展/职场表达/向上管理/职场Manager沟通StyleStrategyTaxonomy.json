      "name": "团队分布分析页",
      "components": ["风格分布图", "高压风格占比", "返工关联图", "满意度关联图"]
    },
    {
      "view_code": "manager_self_check",
      "name": "管理者自检页",
      "components": ["自评他评差异", "风险行为提示", "替代表达建议", "改进行动清单"]
    }
  ],
  "extensibility": {
    "style_registry": "新增风格通过StyleTaxonomy注册，不修改历史记录结构",
    "strategy_registry": "策略条目模板化，支持新增行业、角色、场景分库",
    "versioning": "画像维度、匹配规则和展示文案均使用schema_version控制兼容",
