  "matching_algorithm": {
    "input_objects": ["profile_vector", "style_type", "scenario_code", "goal_type", "risk_level", "historical_effect", "constraints"],
    "scoring_formula": "0.35*ProfileFit + 0.30*ScenarioFit + 0.20*HistoricalEffect + 0.15*ConstraintCompatibility",
    "top_n": 3,
    "fallback_rule": "当画像置信度不足时，退回通用保守策略：结论先行 + 风险前置 + 书面确认",
    "feedback_fields": ["adoption_flag", "decision_speed_delta", "rework_delta", "manager_feedback_score", "followup_questions_count"]
  },
  "visualization_views": [
    {
      "view_code": "manager_profile_dashboard",
