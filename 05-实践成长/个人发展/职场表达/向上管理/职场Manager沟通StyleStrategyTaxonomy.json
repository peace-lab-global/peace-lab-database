{
  "database_name": "管理者沟通风格画像与适配策略数据库",
  "version": "1.0.0",
  "schema_version": "1.0.0",
  "scope": "05-Praxis-Growth/personal-development/workplace-expression",
  "module_name": "manager_communication_style_profiling",
  "assessment_model": {
    "name": "six_dimension_nine_metric_model",
    "dimensions": [
      {
        "code": "information_processing",
        "name": "信息处理偏好",
        "metrics": ["info_conclusion_bias", "detail_tolerance"]
      },
      {
        "code": "decision_pacing",
        "name": "决策节奏偏好",
        "metrics": ["decision_speed", "risk_tolerance"]
      },
      {
        "code": "feedback_interaction",
        "name": "反馈互动风格",
        "metrics": ["feedback_intensity", "support_warmth"]
      },
      {
        "code": "control_collaboration",
        "name": "协作控制方式",
        "metrics": ["control_orientation"]
      },
      {
        "code": "evidence_trust",
        "name": "证据与信任模式",
        "metrics": ["evidence_preference"]
      },
      {
        "code": "channel_cadence",
        "name": "渠道与节奏习惯",
        "metrics": ["sync_frequency_need"]
      }
    ],
    "metrics": [
      {
        "code": "info_conclusion_bias",
        "name": "结论先行偏好",
        "range": "1-5",
        "description": "越高越偏好先听结论与建议"
      },
      {
        "code": "detail_tolerance",
        "name": "细节容忍度",
        "range": "1-5",
        "description": "越高越愿意处理长链路细节"
      },
      {
        "code": "decision_speed",
        "name": "决策速度偏好",
        "range": "1-5",
        "description": "越高越倾向快速拍板"
      },
      {
        "code": "risk_tolerance",
        "name": "风险容忍度",
        "range": "1-5",
        "description": "越高越能接受试错和不完全信息"
      },
      {
        "code": "feedback_intensity",
        "name": "反馈强度",
        "range": "1-5",
        "description": "越高表达越直接、压强越大"
      },
      {
        "code": "support_warmth",
        "name": "支持温度",
        "range": "1-5",
        "description": "越高越支持解释、辅导与鼓励"
      },
      {
        "code": "control_orientation",
        "name": "控制倾向",
        "range": "1-5",
        "description": "越高越偏向过程控制与节点追踪"
      },
      {
        "code": "evidence_preference",
        "name": "证据偏好",
        "range": "1-5",
        "description": "越高越信数据、报表与书面证据"
      },
      {
        "code": "sync_frequency_need",
        "name": "同步频率需求",
        "range": "1-5",
        "description": "越高越需要高频状态更新"
      }
    ],
    "data_sources": [
      {
        "code": "behavior_observation",
        "weight": 0.35,
        "description": "会议、1:1、邮件、纪要中的行为观察"
      },
      {
        "code": "survey_questionnaire",
        "weight": 0.25,
        "description": "管理者自评、下属反馈与结构化问卷"
      },
      {
        "code": "digital_signals",
        "weight": 0.25,
        "description": "项目管理、审批、沟通平台中的数字行为信号"
      },
      {
        "code": "feedback_360",
        "weight": 0.15,
        "description": "平级、下属、HRBP 的360校准反馈"
      }
    ]
  },
  "style_types": [
    {
      "style_code": "result_driver",
      "style_name": "结果驱动型",
      "traits": ["结论导向", "推进速度快", "对长解释耐受低"],
      "score_pattern": {
        "info_conclusion_bias": ">=4",
        "decision_speed": ">=4",
        "detail_tolerance": "<=3"
      },
      "advantages": ["拍板快", "聚焦结果"],
      "risks": ["容易忽略细节风险", "可能压缩讨论空间"]
    },
    {
      "style_code": "structured_analyst",
      "style_name": "结构审慎型",
      "traits": ["重逻辑", "重证据", "偏审慎"],
      "score_pattern": {
        "detail_tolerance": ">=4",
        "evidence_preference": ">=4",
        "risk_tolerance": "<=3"
      },
      "advantages": ["判断稳", "复盘强"],
      "risks": ["拍板慢", "对材料要求高"]
    },
    {
      "style_code": "pressure_accelerator",
      "style_name": "速度压强型",
      "traits": ["高频追进度", "催动强", "反馈直接"],
      "score_pattern": {
        "decision_speed": ">=4",
        "feedback_intensity": ">=4",
        "sync_frequency_need": ">=4"
      },
      "advantages": ["推进强", "紧迫感足"],
      "risks": ["团队焦虑", "信息噪音高"]
    },
    {
      "style_code": "supportive_coach",
      "style_name": "支持辅导型",
      "traits": ["愿意解释", "支持温度高", "重长期成长"],
      "score_pattern": {
        "support_warmth": ">=4",
        "feedback_intensity": "<=3",
        "risk_tolerance": ">=3"
      },
      "advantages": ["心理安全较好", "利于培养人"],
      "risks": ["执行锐度可能不足"]
    },
    {
      "style_code": "detail_controller",
      "style_name": "细节控制型",
      "traits": ["过程追踪密", "节点意识强", "控制倾向高"],
      "score_pattern": {
        "control_orientation": ">=4",
        "detail_tolerance": ">=4",
        "sync_frequency_need": ">=4"
      },
      "advantages": ["落地细", "过程可控"],
      "risks": ["微观管理", "团队疲惫"]
    },
    {
      "style_code": "delegating_builder",
      "style_name": "授权成长型",
      "traits": ["放权", "抓关键节点", "看结果复盘"],
      "score_pattern": {
        "control_orientation": "<=3",
        "support_warmth": ">=3",
        "info_conclusion_bias": ">=3"
      },
      "advantages": ["培养梯队", "效率高"],
      "risks": ["同步不足时易偏航"]
    }
  ],
  "scenario_taxonomy": [
    {"scenario_code": "goal_alignment", "name": "目标对齐", "goal_type": "clarify_priority"},
    {"scenario_code": "weekly_sync", "name": "周度同步", "goal_type": "status_update"},
    {"scenario_code": "risk_alert", "name": "风险预警", "goal_type": "early_escalation"},
    {"scenario_code": "resource_request", "name": "资源申请", "goal_type": "gain_support"},
    {"scenario_code": "cross_function_block", "name": "跨部门受阻", "goal_type": "remove_blocker"},
    {"scenario_code": "bad_news_reporting", "name": "坏消息上报", "goal_type": "damage_control"},
    {"scenario_code": "proposal_disagreement", "name": "方案分歧", "goal_type": "influence_decision"},
    {"scenario_code": "meeting_pressure", "name": "会议高压追问", "goal_type": "stabilize_dialogue"},
    {"scenario_code": "decision_memo", "name": "决策备忘录", "goal_type": "decision_support"},
    {"scenario_code": "monthly_review", "name": "月度复盘", "goal_type": "build_trust"}
  ],
  "strategy_templates": [
