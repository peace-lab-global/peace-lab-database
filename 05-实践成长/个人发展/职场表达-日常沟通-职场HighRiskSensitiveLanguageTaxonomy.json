{
  "database_name": "高风险敏感语料数据库",
  "version": "1.0.0",
  "schema_version": "1.0.0",
  "scope": "content_safety_moderation",
  "storage_path": "05-Praxis-Growth/personal-development/workplace-expression",
  "safety_note": "当前条目采用脱敏占位、规则模板和模式特征表示，不直接公开原始危险表达。",
  "categories": [
    {
      "code": "violence",
      "name": "暴力威胁与煽动",
      "subcategories": ["direct_threat", "incitement", "graphic_violence", "weapon_reference"]
    },
    {
      "code": "extremism",
      "name": "极端主义与恐怖宣传",
      "subcategories": ["propaganda", "recruitment", "symbolic_reference", "coded_support"]
    },
    {
      "code": "hate_discrimination",
      "name": "仇恨与歧视性表达",
      "subcategories": ["slur_attack", "dehumanization", "group_exclusion", "protected_group_hostility"]
    },
    {
      "code": "sexual_coercion",
      "name": "性胁迫与剥削性表达",
      "subcategories": ["coercion", "transactional_exploitation", "minor_risk", "power_imbalance_pressure"]
    },
    {
      "code": "self_harm_incitation",
      "name": "自伤/自杀煽动",
      "subcategories": ["encouragement", "despair_push", "self_harm_instruction_hint"]
    },
    {
      "code": "privacy_doxxing",
      "name": "隐私暴露与人肉威胁",
      "subcategories": ["identity_exposure", "location_exposure", "contact_release", "offline_harassment"]
    },
    {
      "code": "harassment",
      "name": "持续骚扰与定向围猎",
      "subcategories": ["targeted_abuse", "coordinated_harassment", "stalking_hint", "repeat_attack"]
    },
    {
      "code": "illegal_solicitation",
      "name": "违法危险活动招募",
      "subcategories": ["dangerous_trade", "black_market_recruitment", "evasion_code", "regulated_item_solicitation"]
    }
  ],
  "tag_dimensions": {
    "intent": ["threat", "incitement", "propaganda", "recruitment", "humiliation", "exclusion", "coercion", "exposure", "harassment", "solicitation"],
    "target_type": ["individual", "group", "protected_group", "minor", "organization", "public_figure", "unknown_target"],
    "explicitness": ["explicit", "implicit", "coded", "metaphorical", "quoted_context"],
    "expression_form": ["keyword", "phrase", "sentence", "multi_sentence", "symbolic_reference", "emoji_variant"],
    "obfuscation": ["homophone", "split_token", "number_letter_mix", "symbol_insertion", "abbreviation", "cross_language"],
    "action_stage": ["observe", "restrict", "urgent_review", "block_escalate"],
    "language_variant": ["zh_cn", "zh_mixed", "en", "cross_language"]
  },
  "risk_levels": [
    {
      "level": "L1",
      "score_range": "0-24",
      "definition": "弱敏感信号，需结合上下文判断",
      "recommended_action": "observe"
    },
    {
      "level": "L2",
      "score_range": "25-49",
      "definition": "明显风险线索，建议限制传播并复核",
      "recommended_action": "restrict"
    },
    {
      "level": "L3",
      "score_range": "50-74",
      "definition": "高风险内容，需紧急人工复核",
      "recommended_action": "urgent_review"
    },
    {
      "level": "L4",
      "score_range": "75-100",
      "definition": "极高风险内容，应立即拦截并升级",
      "recommended_action": "block_escalate"
    }
  ],
  "risk_scoring": {
    "formula": "intent_strength + target_specificity + actionability + temporal_urgency + group_harm_factor + evasion_complexity",
    "weights": {
      "intent_strength": 30,
      "target_specificity": 20,
      "actionability": 20,
      "temporal_urgency": 10,
      "group_harm_factor": 10,
      "evasion_complexity": 10
    }
  },
  "normalization_pipeline": [
    "全半角统一",
    "大小写折叠",
    "去除重复空格与无意义符号",
    "常见谐音/缩写/数字字母替换归一化",
    "表情、分隔符、插入符清洗",
    "跨语种混写切分",
    "受控词典映射到内部真实词表"
  ],
  "retrieval_indexes": [
    {
      "name": "idx_category_risk",
      "fields": ["category", "risk_level"],
      "purpose": "按大类与风险等级快速筛选"
    },
    {
      "name": "idx_tags",
      "fields": ["tags", "target_types", "obfuscation_forms"],
      "purpose": "按多维标签组合召回"
    },
    {
      "name": "idx_search_keys",
      "fields": ["search_keys", "language_variants"],
      "purpose": "按关键词、变体和语言检索"
    },
    {
      "name": "idx_pattern_templates",
      "fields": ["pattern_templates"],
      "purpose": "支撑规则引擎与模式匹配"
    },
    {
      "name": "idx_related_entries",
      "fields": ["related_entries"],
      "purpose": "做相似语义扩展与关联分析"
    }
  ],
  "extension_interfaces": {
    "api": [
      "POST /entries",
      "PATCH /entries/{id}",
      "GET /entries/search",
      "GET /entries/export",
      "POST /rules/similarity-expand",
      "POST /review/batch"
    ],
    "required_entry_fields": [
      "id",
      "title",
      "alias",
      "category",
      "subcategory",
      "risk_level",
      "severity_score",
      "tags",
      "target_types",
      "signal_features",
      "search_keys",
      "pattern_templates",
      "recommended_action"
    ],
    "optional_entry_fields": [
      "context_note",
      "source_channel",
      "review_status",
      "related_entries",
      "jurisdiction",
      "updated_at",
      "hard_negative_patterns"
    ]
  },
